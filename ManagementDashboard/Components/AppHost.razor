@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Routing
@using ManagementDashboard
@using ManagementDashboard.Components.Layout

<Router AppAssembly="@typeof(ManagementDashboard.App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(ManagementDashboard.Components.Layout.MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="@typeof(ManagementDashboard.Components.Layout.MainLayout)">
            <MudText Typo="Typo.h6" Color="Color.Error">Page not found.</MudText>
        </LayoutView>
    </NotFound>
</Router>
